{
  "name": "drinkwars-server",
  "version": "0.1.0",
  "description": "Drink Wars — persistence + orchestration layer (round lifecycle, engine invocation, append-only history). Storage-adapter abstracted; Supabase schema in supabase/migrations.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "demo": "tsx src/demo.ts",
    "serve": "tsx src/transport.ts",
    "transport:smoke": "tsx src/transport-smoke.ts",
    "supabase:smoke": "tsx src/supabase-smoke.ts",
    "supabase:join": "tsx src/supabase-join-smoke.ts",
    "dashboard:smoke": "tsx src/dashboard-smoke.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build:edge": "esbuild src/edge-core.ts --bundle --format=esm --platform=neutral --external:@supabase/supabase-js --outfile=supabase/functions/drinkwars/drinkwars-core.js",
    "cleanup:test": "tsx src/cleanup-test-users.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "drinkwars-engine": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "esbuild": "^0.28.0"
  }
}
