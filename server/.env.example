# ────────────────────────────────────────────────────────────────────────
# Drink Wars — Supabase backend (multiplayer)
#
# This is the committed TEMPLATE. Your real values go in server/.env
# (already created for you, and gitignored — secrets never get committed).
#
# Every value comes from your Supabase project dashboard. The click-path is
# the gear "Project Settings" at the bottom-left of the project.
# ────────────────────────────────────────────────────────────────────────

# Project URL  —  Project Settings → API → "Project URL"
# Looks like: https://abcdefghijklmnop.supabase.co
# Not secret (also used in the browser).            >>> SEND THIS BACK TO ME
SUPABASE_URL=

# anon / public key  —  Project Settings → API → Project API keys → "anon public"
# Safe for the browser; every table is guarded by Row-Level Security.
# Not secret.                                        >>> SEND THIS BACK TO ME
SUPABASE_ANON_KEY=

# service_role key  —  same page → "service_role" (click the eye to reveal)
# !!! SECRET !!!  Bypasses Row-Level Security; server-side only.
# Do NOT paste this in chat — just drop it in server/.env (it's gitignored).
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: only if we apply the schema via the Supabase CLI/psql instead
#    of the dashboard SQL editor (the easy path needs nothing here). ───────
# Connection string  —  Project Settings → Database → "Connection string" → URI
# Contains your database password. SECRET — keep it in server/.env only.
SUPABASE_DB_URL=
